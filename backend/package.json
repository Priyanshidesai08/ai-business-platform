{
  "name": "ai-business-platform-backend",
  "version": "1.0.0",
  "description": "Backend API for the Multi-Agent AI Business Automation Platform.",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "node scripts/lint.js",
    "test": "npm run smoke && npm run test:unit && npm run test:integration",
