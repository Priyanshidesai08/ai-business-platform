            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/orchestrator/preview",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request\": \"Generate campaign for new customer\",\n  \"context\": {}\n}"
            }
          }
        }
      ]
    }
  ],
