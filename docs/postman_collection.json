  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Priya Sharma\",\n  \"email\": \"priya@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"priya@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            }
          }
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/auth/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Priya Sharma\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Orchestrator",
      "item": [
        {
          "name": "Run Orchestration",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/orchestrator/run",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request\": \"Generate campaign for new customer\",\n  \"goal\": \"Qualify the lead, create a campaign, and summarize impact.\",\n  \"context\": {\n    \"customer\": {\n      \"name\": \"Acme Corp\",\n      \"email\": \"buyer@acme.com\",\n      \"company\": \"Acme Corp\"\n    }\n  }\n}"
            }
          }
        },
        {
          "name": "Workflow Preview",
          "request": {
